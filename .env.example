# ============================================================================
# The Crude Oracle — environment variables
# ----------------------------------------------------------------------------
# Copy to .env.local for local dev, or set in Vercel/Netlify dashboard.
# NEVER commit .env.local or real keys to git (.gitignore already excludes it).
# NEVER put secret keys in frontend code or NEXT_PUBLIC_* variables.
# ============================================================================

# --- Stripe (server-side secrets — set only in hosting dashboard) -----------
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxx_replace_me
# From your webhook endpoint config: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx_replace_me
# Price ID for The Crude Oracle Premium (£299.99/month recurring)
PRICE_ID_CRUDE_ORACLE_PREMIUM=price_xxx_replace_me

# --- Stripe (safe to expose to the browser) ---------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx_replace_me

# --- Simplest option: Stripe Payment Link (no keys needed) ------------------
# If you only use a Payment Link, you don't need any of the keys above.
# Paste the link into STRIPE_SUBSCRIPTION_LINK in src/lib/site.ts instead:
#   https://buy.stripe.com/xxxxxxxxxxxx

# --- Auth placeholder (Phase 2: Supabase) ------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me_server_only

# --- Market data API placeholders (Phase 3) ----------------------------------
ALPHA_VANTAGE_API_KEY=replace_me
POLYGON_API_KEY=replace_me
NASDAQ_DATA_LINK_API_KEY=replace_me
